enum day_of_week {
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
  sunday
}

enum group_member_role {
  owner
  moderator
  member
}

enum notification_type {
  session_reminder
  group_invitation
  goal_achieved
  session_comment
  group_session_created
  member_joined
  session_cancelled
  weekly_report
}

enum priority_level {
  low
  medium
  high
  critical
}

enum session_status {
  planned
  in_progress
  completed
  cancelled
  missed
}

enum session_type {
  solo
  group
}

enum user_role {
  admin
  user
}

enum user_status {
  active
  inactive
  banned
  pending
}
