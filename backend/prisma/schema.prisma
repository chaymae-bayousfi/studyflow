/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model study_groups {
  id              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_by      String           @db.Uuid
  name            String           @db.VarChar(150)
  description     String?
  avatar_url      String?
  color           String           @default("#1fc87a") @db.VarChar(7)
  subject_id      String?          @db.Uuid
  is_public       Boolean          @default(false)
  max_members     Int              @default(20)
  invitation_code String?          @unique @db.VarChar(12)
  is_active       Boolean          @default(true)
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime         @default(now()) @db.Timestamptz(6)
  group_members   group_members[]
  group_messages  group_messages[]
  users           users            @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  subjects        subjects?        @relation(fields: [subject_id], references: [id], onUpdate: NoAction)

  @@index([created_by], map: "idx_groups_created_by")
  @@index([invitation_code], map: "idx_groups_invite_code")
  @@index([is_public], map: "idx_groups_is_public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model study_sessions {
  id                   String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id              String                 @db.Uuid
  subject_id           String?                @db.Uuid
  weekly_schedule_id   String?                @db.Uuid
  title                String                 @db.VarChar(255)
  description          String?
  session_type         session_type           @default(solo)
  status               session_status         @default(planned)
  priority             priority_level         @default(medium)
  location             String?                @db.VarChar(255)
  is_online            Boolean                @default(false)
  meeting_url          String?
  planned_start        DateTime               @db.Timestamptz(6)
  planned_end          DateTime               @db.Timestamptz(6)
  actual_start         DateTime?              @db.Timestamptz(6)
  actual_end           DateTime?              @db.Timestamptz(6)
  planned_duration_min Int?                   @default(dbgenerated("(EXTRACT(epoch FROM (planned_end - planned_start)) / (60)::numeric)"))
  actual_duration_min  Int?                   @default(dbgenerated("\nCASE\n    WHEN ((actual_start IS NOT NULL) AND (actual_end IS NOT NULL)) THEN (EXTRACT(epoch FROM (actual_end - actual_start)) / (60)::numeric)\n    ELSE NULL::numeric\nEND"))
  notes                String?
  productivity_rating  Int?                   @db.SmallInt
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  deleted_at           DateTime?              @db.Timestamptz(6)
  session_comments     session_comments[]
  session_participants session_participants[]
  subjects             subjects?              @relation(fields: [subject_id], references: [id], onUpdate: NoAction)
  users                users                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  weekly_schedules     weekly_schedules?      @relation(fields: [weekly_schedule_id], references: [id], onUpdate: NoAction)

  @@index([user_id, planned_start, planned_end], map: "idx_sessions_overlap")
  @@index([planned_start], map: "idx_sessions_planned_start")
  @@index([weekly_schedule_id], map: "idx_sessions_schedule_id")
  @@index([status], map: "idx_sessions_status")
  @@index([subject_id], map: "idx_sessions_subject_id")
  @@index([user_id], map: "idx_sessions_user_id")
}

