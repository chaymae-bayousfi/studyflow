  password_hash                                 String
  first_name                                    String                 @db.VarChar(100)
  last_name                                     String                 @db.VarChar(100)
  avatar_url                                    String?
  role                                          user_role              @default(user)
  status                                        user_status            @default(pending)
  xp_points                                     Int                    @default(0)
  level                                         Int                    @default(1)
